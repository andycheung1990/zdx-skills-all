{
  "name": "yuque-upload",
  "version": "1.0.0",
  "description": "语雀文档自动上传工具 - 支持 Markdown 文件批量上传到语雀知识库",
  "author": "OpenClaw Community",
  "license": "MIT",
  "minOpenclawVersion": "2026.3.13",
  "commands": {
    "setup": {
      "description": "配置语雀 API Token",
      "script": "scripts/setup.sh"
    },
    "upload": {
      "description": "上传单个文档到语雀",
      "script": "scripts/upload.sh"
    },
    "upload-batch": {
      "description": "批量上传文档",
      "script": "scripts/upload-batch.sh"
    },
    "list-repos": {
      "description": "列出可用的知识库",
      "script": "scripts/list-repos.sh"
    },
    "list-docs": {
      "description": "列出知识库中的文档",
      "script": "scripts/list-docs.sh"
    }
  },
  "config": {
    "configPath": "config/yuque-config.json"
  },
  "docs": {
    "guide": "docs/usage-guide.md"
  }
}
